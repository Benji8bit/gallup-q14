# Переменные окружения

# Обязательно: пароль для доступа HR к дашборду и экспорту (локально — placeholder)
ADMIN_PASSWORD=change-me

# Порт HTTP-сервера (по умолчанию 8080)
PORT=8080

# Путь к файлу SQLite (по умолчанию ./data/gallup-q14.db)
DB_PATH=./data/gallup-q14.db

# Delivery Sapiens — локальное зеркало (offline) и pull из PostgreSQL (VPN, ~раз в месяц)
# DELIVERY_MIRROR_PATH=./backend/data/delivery_mirror.db
# DELIVERY_REFERENCE_SEED_PATH=./scripts/delivery_reference_seed.sql
# DELIVERY_SAPIENS_DB_HOST=<delivery-host>
# DELIVERY_SAPIENS_DB_PORT=5432
# DELIVERY_SAPIENS_DB_NAME=postgres
# DELIVERY_SAPIENS_DB_USER=<db-user>
# DELIVERY_SAPIENS_DB_PASSWORD=

# Пересборка справочника из зеркала (часы). 0 = только вручную / кнопка на дашборде
DELIVERY_SYNC_INTERVAL_HOURS=24

# Origin фронтенда для CORS (по умолчанию http://localhost:5173)
CORS_ORIGIN=http://localhost:5173
